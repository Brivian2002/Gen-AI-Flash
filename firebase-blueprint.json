{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with credit tracking and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "credits": { "type": "integer", "description": "Search credits remaining" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "credits"]
    },
    "SearchHistory": {
      "title": "Search History",
      "description": "Log of searches performed by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "response"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/searches/{searchId}": {
      "schema": "SearchHistory",
      "description": "Global search history or user-specific if queried correctly"
    }
  }
}
